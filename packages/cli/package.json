{
  "name": "@rnboost/cli",
  "version": "0.1.0",
  "description": "RNBoost CLI — scaffold a production-ready React Native app in one command.",
  "bin": {
    "rnboost": "./bin/rnboost.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node bin/rnboost.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "cli",
    "expo",
    "scaffold",
    "ai-codegen"
  ],
  "author": "Ismael Blaise",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^12.1.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
