{
  "name": "rnboost-cli-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "RNBoost CLI — the smart React Native starter. Monorepo root.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "cli": "npm run start --workspace @rnboost/cli",
    "docs:dev": "npm run dev --workspace @rnboost/docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismaelBlaise/rnboost-cli.git"
  },
  "keywords": [
    "react-native",
    "cli",
    "starter",
    "scaffold",
    "expo",
    "ai"
  ],
  "author": "Ismael Blaise <marketing@nuklear.io>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
